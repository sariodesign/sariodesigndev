---
import { slide } from "astro:transitions";
import aboutMePhoto from "../assets/about-me-photo.jpg";
import TechLogo from "../components/TechLogo.astro";
import { defaultLocale, getLocalizedPath, type Locale } from "../i18n/config";
import type { Dictionary } from "../i18n";

interface Props {
	dict: Dictionary;
	locale: Locale;
}

const { dict, locale } = Astro.props;
const worksHref =
	locale === defaultLocale ? "/works" : getLocalizedPath(locale, "/works");
const servicesHref =
	locale === defaultLocale
		? "/services"
		: getLocalizedPath(locale, "/services");
---

<main transition:name="main" transition:animate={slide()}>
	<div class="home-intro">
		<div class="home-photo-wrap">
			<img
				class="home-photo"
				cursor-class="photo-home"
				src={aboutMePhoto.src}
				alt={dict.home.photoAlt}
				width="360"
				height="360"
				loading="eager"
				decoding="async"
			/>
		</div>
		<div class="home-copy">
			<a
				class="availability-badge"
				href="mailto:hello@sariodesign.dev"
				cursor-class="link"
			>
				<span class="availability-badge__dot" aria-hidden="true"></span>
				<span>{dict.home.availability}</span>
			</a>
			<h1 cursor-class="text" id="intro">
				<span class="intro-line-wrap">
					<span class="intro-line">
						{dict.home.headingStart}{" "}
						<span class="evidence">{dict.home.headingHighlightFast}</span>
						{` ${dict.home.headingMiddle} `}
						<span class="evidence">{dict.home.headingHighlightEasy}</span>
						{` ${dict.home.headingEnd}`}
					</span>
				</span>
				<span class="intro-line-wrap">
					<span class="intro-line intro-line--tags">
						{
							dict.home.headingTags.map((tag, index) => (
								<span class="intro-tag-item">
									{index > 0 && (
										<span class="intro-tag-dot" aria-hidden="true"></span>
									)}
									<span class="intro-tag">{tag}</span>
								</span>
							))
						}
					</span>
				</span>
			</h1>
			<section class="home-value js-home-value" cursor-class="text">
				<p class="home-value__eyebrow">{dict.home.valueEyebrow}</p>
				<div class="home-value__grid">
					{
						dict.home.offers.map((offer, index) => (
							<article class="home-value-card">
								<span class="home-value-card__badge">{`0${index + 1}`}</span>
								<h2 class="home-value-card__title">{offer.title}</h2>
								<p class="home-value-card__description">{offer.description}</p>
							</article>
						))
					}
				</div>
				<div class="home-stack">
					<span class="home-stack__label">{dict.home.stackLabel}</span>
						<ul class="home-stack__list" aria-label={dict.home.stackLabel}>
							{
								dict.home.stackItems.map((item) => (
									<li class="home-stack__item">
										<TechLogo name={item} />
									</li>
								))
							}
						</ul>
				</div>
			</section>
			<div class="home-cta">
				<a
					class="home-cta__btn home-cta__btn--primary"
					href={worksHref}
					data-astro-reload
					cursor-class="link"
				>
					{dict.home.ctaWorks}
				</a>
				<a
					class="home-cta__btn home-cta__btn--secondary"
					href={servicesHref}
					data-astro-reload
					cursor-class="link"
				>
					{dict.home.ctaEmail}
				</a>
			</div>
			</div>
		</div>
	</main>

<script>
	import { gsap } from "gsap";

	const intro = document.querySelector("#intro");
	const introLines = document.querySelectorAll(".intro-line");
	const availabilityBadge = document.querySelector(".availability-badge");
	const homePhoto = document.querySelector(".home-photo");
	const homeValue = document.querySelector(".js-home-value");
	const homeCta = document.querySelector(".home-cta");

	if (intro) {
		gsap.set(intro, { autoAlpha: 1 });
	}
	if (homePhoto) {
		gsap.set(homePhoto, { autoAlpha: 0 });
	}

	const introTimeline = gsap.timeline({ delay: 0.15 });
	if (homePhoto) {
		introTimeline.fromTo(
			homePhoto,
			{
				y: 28,
				scale: 0.94,
				rotate: -2.5,
				autoAlpha: 0,
			},
			{
				y: 0,
				scale: 1,
				rotate: 0,
				autoAlpha: 1,
				duration: 0.95,
				ease: "power3.out",
			},
			0,
		);
	}
	if (availabilityBadge) {
		introTimeline.fromTo(
			availabilityBadge,
			{
				y: 14,
				opacity: 0,
			},
			{
				y: 0,
				opacity: 1,
				duration: 0.55,
				ease: "power3.out",
			},
			0.05,
		);
	}
	introTimeline.fromTo(
		introLines,
		{
			yPercent: 120,
			rotateX: -22,
			opacity: 0,
		},
		{
			yPercent: 0,
			rotateX: 0,
			opacity: 1,
			stagger: 0.13,
			duration: 1.05,
			ease: "power4.out",
		},
		0.1,
	);
	if (homeValue) {
		introTimeline.fromTo(
			homeValue,
			{
				y: 18,
				opacity: 0,
			},
			{
				y: 0,
				opacity: 1,
				duration: 0.55,
				ease: "power3.out",
			},
			0.28,
		);
	}
	if (homeCta) {
		introTimeline.fromTo(
			homeCta,
			{
				y: 12,
				opacity: 0,
			},
			{
				y: 0,
				opacity: 1,
				duration: 0.55,
				ease: "power2.out",
			},
			0.42,
		);
	}

	gsap.to(".footer", {
		y: 0,
		opacity: 1,
		stagger: 0.05,
		delay: 0.2,
		duration: 0.5,
	});
</script>

<style is:global>
	h1 {
		color: #fff;
		font-size: clamp(1.25rem, 4vw, 2.75rem);
		line-height: 1.08;
		margin: 0;
		opacity: 0;
		perspective: 1000px;
		transition: opacity 0.15s;
		visibility: visible;
	}

	.intro-line-wrap {
		display: block;
		overflow: hidden;
	}

	.intro-line {
		display: block;
		transform-origin: 50% 100%;
		will-change: transform, opacity;
	}

	.intro-line-wrap + .intro-line-wrap {
		margin-top: 0.55rem;
	}

	.intro-line--tags {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem 0.8rem;
		font-size: clamp(0.84rem, 1.4vw, 1.08rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.intro-tag-item {
		align-items: center;
		display: inline-flex;
		gap: 0.8rem;
	}

	.intro-tag-dot {
		background-color: var(--orange);
		border-radius: 50%;
		display: inline-block;
		height: 0.42rem;
		width: 0.42rem;
	}

	.home-value {
		display: grid;
		gap: 14px;
		margin-top: 1.4rem;
		max-width: min(860px, 100%);
	}

	.home-value__eyebrow {
		color: var(--orange);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		margin: 0;
		text-transform: uppercase;
	}

	.home-value__grid {
		display: grid;
		gap: 12px;
	}

	.home-value-card {
		backdrop-filter: blur(8px);
		border-radius: 18px;
		display: grid;
		gap: 10px;
		padding: 16px;
	}

	.home-value-card__badge {
		align-items: center;
		border-radius: 12px;
		color: var(--orange);
		display: inline-flex;
		font-size: 0.75rem;
		font-weight: 700;
		height: 40px;
		justify-content: center;
		letter-spacing: 0.08em;
		width: 40px;
	}

	.home-value-card__title {
		font-family: var(--base-font-family-serif);
		font-size: clamp(1rem, 1.4vw, 1.18rem);
		line-height: 1.1;
		margin: 0;
	}

	.home-value-card__description {
		font-size: 0.92rem;
		line-height: 1.55;
		margin: 0;
	}

	.home-stack {
		display: grid;
		gap: 10px;
		padding-top: 4px;
	}

	.home-stack__label {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.home-stack__list {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 10px 18px;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.home-stack__item {
		align-items: center;
		border-radius: 16px;
		display: inline-flex;
		height: 58px;
		justify-content: center;
		padding: 0;
		width: 58px;
	}

	.tech-logo__img,
	.tech-logo__fallback {
		align-items: center;
		display: inline-flex;
		height: 28px;
		justify-content: center;
		width: 28px;
	}

	.tech-logo__img {
		object-fit: contain;
	}

	.tech-logo__fallback {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.home-cta {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin-top: 1.35rem;
		opacity: 0;
		width: min(420px, 100%);
	}

	.home-cta__btn {
		align-items: center;
		border-radius: 12px;
		display: inline-flex;
		font-size: clamp(0.95rem, 1.2vw, 1.02rem);
		font-weight: 700;
		justify-content: center;
		min-height: 48px;
		padding: 0.65rem 1rem;
		text-decoration: none;
		transition: transform 0.2s ease, filter 0.2s ease;
	}

	.home-cta__btn:hover {
		filter: brightness(0.97);
		transform: translateY(-1px);
	}

	.home-cta__btn--primary {
		background-color: var(--dark-black);
		border: 1px solid var(--dark-black);
		color: var(--white);
	}

	.home-cta__btn--secondary {
		backdrop-filter: blur(4px);
		background-color: rgba(255, 255, 255, 0.35);
		border: 1px solid rgba(16, 32, 32, 0.2);
		color: var(--dark-black);
	}

	.availability-badge {
		align-items: center;
		backdrop-filter: blur(5px);
		border: 1px solid transparent;
		border-radius: 999px;
		display: inline-flex;
		font-size: clamp(0.84rem, 1.05vw, 0.94rem);
		font-weight: 700;
		gap: 10px;
		letter-spacing: 0.03em;
		margin: 0 0 1rem;
		opacity: 0;
		padding: 0.5rem 0.95rem;
		text-decoration: none;
		text-transform: uppercase;
	}

	.availability-badge__dot {
		animation: badgePulse 1.8s ease-out infinite;
		border-radius: 50%;
		display: inline-block;
		height: 9px;
		width: 9px;
	}

	@keyframes badgePulse {
		0% {
			box-shadow: 0 0 0 0 rgba(45, 219, 143, 0.45);
		}
		70% {
			box-shadow: 0 0 0 9px rgba(45, 219, 143, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(45, 219, 143, 0);
		}
	}

	@media (prefers-color-scheme: dark) {
		h1 {
			color: #fff;
		}

		.availability-badge {
			background: linear-gradient(
				120deg,
				rgba(64, 236, 156, 0.12),
				rgba(38, 147, 95, 0.18)
			);
			border-color: rgba(101, 226, 167, 0.35);
			color: #7cf0ba;
		}

		.availability-badge__dot {
			background: #49e6a0;
		}

		.home-value-card {
			background-color: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
		}

		.home-value-card__badge {
			background-color: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
		}

		.home-value-card__title,
		.home-stack__item {
			color: #f3f4f8;
		}

		.home-value-card__description,
		.home-stack__label {
			color: #c0c3cb;
		}

		.home-stack__item {
			background-color: rgba(255, 255, 255, 0.05);
			border: 1px solid rgba(255, 255, 255, 0.12);
		}

		.home-cta__btn--primary {
			background-color: #f3f4f8;
			border-color: #f3f4f8;
			color: #102020;
		}

		.home-cta__btn--secondary {
			background-color: rgba(255, 255, 255, 0.08);
			border-color: rgba(255, 255, 255, 0.2);
			color: var(--white);
		}
	}
	@media (prefers-color-scheme: light) {
		h1 {
			color: var(--dark-black);
		}

		.availability-badge {
			background: linear-gradient(
				120deg,
				rgba(16, 170, 108, 0.08),
				rgba(16, 170, 108, 0.18)
			);
			border-color: rgba(16, 170, 108, 0.32);
			color: #0f8b5a;
		}

		.availability-badge__dot {
			background: #0da566;
		}

		.home-value-card {
			background-color: rgba(255, 255, 255, 0.46);
			border: 1px solid rgba(16, 32, 32, 0.12);
			box-shadow: 0 18px 38px -34px rgba(16, 32, 32, 0.3);
		}

		.home-value-card__badge {
			background-color: rgba(221, 122, 76, 0.08);
			border: 1px solid rgba(221, 122, 76, 0.16);
		}

		.home-value-card__title {
			color: var(--dark-black);
		}

		.home-value-card__description,
		.home-stack__label {
			color: #5f6571;
		}

		.home-stack__item {
			color: var(--dark-black);
		}

		.home-stack__item {
			background-color: rgba(16, 32, 32, 0.04);
			border: 1px solid rgba(16, 32, 32, 0.1);
		}
	}
	.evidence {
		color: var(--orange);
	}

	main {
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: calc(92px + env(safe-area-inset-top)) 16px 24px;
	}

	.home-intro {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		row-gap: 24px;
		width: 100%;
	}

	.home-photo-wrap {
		align-self: center;
	}

	.home-photo {
		border-radius: 16px;
		box-shadow: 0 20px 60px -30px rgba(0, 0, 0, 0.45);
		display: block;
		height: auto;
		width: clamp(220px, 55vw, 320px);
		will-change: transform, opacity;
	}

	.home-copy {
		width: 100%;
	}

	@media screen and (min-width: 720px) {
		.home-value__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media screen and (min-width: 1024px) {
		main {
			padding: 104px 24px 24px;
		}

		.home-intro {
			align-items: center;
			column-gap: 56px;
			display: flex;
			flex-direction: row-reverse;
			justify-content: space-between;
			max-width: 1440px;
		}

		.home-photo-wrap {
			align-items: center;
			display: flex;
			flex: 0 1 40%;
			justify-content: center;
			align-self: auto;
		}

		.home-photo {
			width: clamp(260px, 26vw, 360px);
		}

		.home-copy {
			align-self: auto;
			flex: 1 1 60%;
			max-width: none;
		}

		.home-cta {
			flex-direction: row;
			width: auto;
		}

		.home-cta__btn {
			min-width: 170px;
		}
	}

	.footer,
	.btn-menu {
		opacity: 0;
		transform: translateY(50px);
		transition: all 0.15s;
	}

	.rounded {
		width: 30px;
		height: 30px;
		border: 2px solid #fff;
		border-radius: 50%;
		z-index: 999;
	}

	canvas {
		display: block;
		background-color: transparent;
		left: 0;
		position: absolute;
		top: 0;
		z-index: -1;
	}
</style>

<script src="../assets/js/main.js"></script>
