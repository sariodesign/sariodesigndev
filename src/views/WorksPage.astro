---
import PageCta from "../components/PageCta.astro";
import type { Dictionary } from "../i18n";
import { getLocalizedPath, type Locale } from "../i18n/config";

interface Props {
	dict: Dictionary;
	locale: Locale;
}

const { dict, locale } = Astro.props;
const projects = dict.works.projects;
const collaborations = dict.works.collaborations;
---

<main class="work-page">
	<section class="work-list" aria-label={dict.works.listAriaLabel}>
		<h1 class="work-title js-work-title">{dict.works.heading}</h1>
		{
			projects.map((project) => (
				<article class="work-row js-work-row">
					<a
						class="work-row-link"
						cursor-class="link"
						href={getLocalizedPath(
							locale,
							`/works/${project.slug}`,
						)}
						aria-label={`${dict.works.openProjectAria} ${project.name}`}
					>
						<div class="work-row-main">
							<h2 class="work-row-title">{project.name}</h2>
							<p class="work-row-description">
								{project.description}
							</p>
						</div>
						<div class="work-row-meta">
							<span>{project.services}</span>
							<span>{project.year}</span>
						</div>
						<span class="work-row-arrow" aria-hidden="true">
							↗
						</span>
						{/* <img
							class="work-row-preview"
							src={project.image}
							alt=""
							aria-hidden="true"
							loading="lazy"
							decoding="async"
						/> */}
					</a>
				</article>
			))
		}
	</section>

	{collaborations && collaborations.length > 0 && (
		<section class="work-list" aria-label={dict.works.collaborationsListAriaLabel} style="margin-top: clamp(6rem, 8vw, 8rem);">
			<h2 class="work-title js-work-title">{dict.works.collaborationsHeading}</h2>
			{
				collaborations.map((project) => (
					<article class="work-row js-work-row">
						<a
							class="work-row-link"
							cursor-class="link"
							href={project.agencyUrl || getLocalizedPath(locale, `/works/${project.slug}`)}
							target={project.agencyUrl ? "_blank" : undefined}
							rel={project.agencyUrl ? "noopener noreferrer" : undefined}
							aria-label={`${dict.works.openProjectAria} ${project.name}`}
						>
							<div class="work-row-main">
								<h3 class="work-row-title">{project.name}</h3>
								<p class="work-row-description">
									{project.description}
								</p>
							</div>
							<div class="work-row-meta">
								<span>{project.services}</span>
								<span>{project.year}</span>
							</div>
							<span class="work-row-arrow" aria-hidden="true">
								↗
							</span>
						</a>
					</article>
				))
			}
		</section>
	)}

	<div class="work-page-cta js-work-row">
		<PageCta dict={dict} locale={locale} showWorksCta={false} />
	</div>
</main>

<script>
	import { gsap } from "gsap";
	import { onPageRevealReady } from "../assets/js/pageReveal.js";

	const reduceMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;
	const titles = [...document.querySelectorAll(".js-work-title")];
	const rows = [...document.querySelectorAll(".js-work-row")];

	if (!reduceMotion) {
		if (titles.length > 0) {
			gsap.set(titles, {
				yPercent: 120,
				rotateX: -14,
				filter: "blur(8px)",
				autoAlpha: 0,
			});
		}
		if (rows.length > 0) {
			gsap.set(rows, { y: 28, autoAlpha: 0 });
		}
	}

	onPageRevealReady(() => {
		if (reduceMotion) {
			if (titles.length > 0) {
				gsap.set(titles, { autoAlpha: 1 });
			}
			return;
		}

		const tl = gsap.timeline();
		if (titles.length > 0) {
			tl.to(titles, {
				yPercent: 0,
				rotateX: 0,
				filter: "blur(0px)",
				autoAlpha: 1,
				duration: 0.9,
				ease: "power4.out",
				stagger: 0.1,
			});
		}
		tl.to(
			rows,
			{
				y: 0,
				autoAlpha: 1,
				duration: 0.55,
				stagger: 0.08,
				ease: "power3.out",
			},
			"-=0.35",
		);
	});

	const canHover = window.matchMedia(
		"(hover: hover) and (pointer: fine)",
	).matches;

	if (canHover) {
		const rowLinks = [...document.querySelectorAll(".work-row-link")];
		let activePreview = null;
		let targetShift = 0;
		let currentShift = 0;
		let rafId = 0;

		const stopLoop = () => {
			if (rafId) {
				cancelAnimationFrame(rafId);
				rafId = 0;
			}
		};

		const runLoop = () => {
			if (!activePreview) return;
			currentShift += (targetShift - currentShift) * 0.3;
			activePreview.style.setProperty(
				"--preview-shift",
				`${currentShift.toFixed(2)}px`,
			);
			rafId = requestAnimationFrame(runLoop);
		};

		const setTargetFromPointer = (event, link) => {
			const rect = link.getBoundingClientRect();
			const pointerX = event.clientX - rect.left;
			const ratio = Math.min(1, Math.max(0, pointerX / rect.width));
			// Range piu ampio per maggiore mobilita orizzontale.
			targetShift = (ratio - 0.5) * 60; // -30px ... +30px
		};

		rowLinks.forEach((link) => {
			link.addEventListener("pointerenter", (event) => {
				const preview = link.querySelector(".work-row-preview");
				if (!preview) return;
				activePreview = preview;
				currentShift = 0;
				targetShift = 0;
				setTargetFromPointer(event, link);
				stopLoop();
				runLoop();
			});

			link.addEventListener("pointermove", (event) => {
				if (!activePreview) return;
				setTargetFromPointer(event, link);
			});

			link.addEventListener("pointerleave", () => {
				stopLoop();
				if (activePreview) {
					activePreview.style.setProperty("--preview-shift", "0px");
				}
				activePreview = null;
				currentShift = 0;
				targetShift = 0;
			});
		});
	}
</script>

<style lang="scss">
	.work-page {
		--work-text: var(--dark-black);
		--work-muted: #5f6571;
		--work-border: rgba(16, 32, 32, 0.18);
		--work-border-hover: rgba(16, 32, 32, 0.36);
		display: block;
		min-height: auto;
		padding: clamp(82px, 11vh, 122px) 0 64px;
		position: relative;
		z-index: 2;
	}

	.work-title {
		color: var(--work-text);
		font-family: var(--base-font-family-serif);
		font-size: clamp(2rem, 8vw, 5.2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 0.92;
		margin: 0 0 24px;
		padding-inline: 16px;
		text-transform: none;
		transform-origin: 50% 100%;
		will-change: transform, filter, opacity;
	}

	.work-list {
		display: block;
		max-width: 1440px;
		width: 100%;
		margin: 0 auto;
	}

	.work-page-cta {
		margin: 32px auto 0;
		max-width: 1440px;
		padding-inline: 16px;
		width: 100%;
	}

	.work-row {
		border-top: 1px solid var(--work-border);
	}

	.work-row:last-child {
		border-bottom: 1px solid var(--work-border);
	}

	.work-row-link {
		--meta-width: 320px;
		--arrow-width: 28px;
		--row-gap: 12px;
		--preview-width: 420px;
		--preview-height: 262px;
		align-items: center;
		background: transparent;
		border: 0;
		color: var(--work-text);
		cursor: pointer;
		display: grid;
		gap: var(--row-gap);
		grid-template-columns: minmax(0, 1fr) var(--meta-width) var(
				--arrow-width
			);
		min-height: 124px;
		overflow: visible;
		padding: 28px 16px;
		position: relative;
		text-align: left;
		text-decoration: none;
		width: 100%;
	}

	.work-row-main {
		min-width: 0;
		padding-right: 8px;
	}

	.work-row-title {
		color: var(--work-text);
		font-family: var(--base-font-family-serif);
		font-size: clamp(1rem, 4vw, 2rem);
		letter-spacing: -0.01em;
		line-height: 0.98;
		margin: 0;
		transform: translateX(0);
		transition: transform 0.25s ease;
	}

	.work-row-description {
		color: var(--work-muted);
		font-size: 0.9rem;
		line-height: 1.4;
		margin: 0.45rem 0 0;
		max-width: 70%;
	}

	.work-row-meta {
		color: var(--work-muted);
		display: flex;
		flex-direction: column;
		font-size: 0.72rem;
		gap: 6px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		text-align: right;
	}

	.work-row-arrow {
		font-size: 1.2rem;
		opacity: 0;
		transform: translate(-6px, 6px);
		transition:
			opacity 0.22s ease,
			transform 0.22s ease;
	}

	.work-row-preview {
		--preview-shift: 0px;
		border: 1px solid rgba(255, 255, 255, 0.45);
		border-radius: 14px;
		box-shadow: 0 22px 36px -24px rgba(0, 0, 0, 0.42);
		height: var(--preview-height);
		object-fit: cover;
		opacity: 0;
		pointer-events: none;
		position: absolute;
		right: calc(
			var(--meta-width) + var(--arrow-width) + (var(--row-gap) * 2) -
				(var(--preview-width) * 0.54)
		);
		top: 50%;
		transform: translate3d(calc(var(--preview-shift) + 12px), -57%, 0)
			scale(0.985);
		transition:
			opacity 0.24s ease,
			transform 0.08s linear;
		will-change: transform, opacity;
		width: var(--preview-width);
		z-index: 2;
	}

	.work-row-link:hover,
	.work-row-link:focus-visible {
		.work-row-title {
			transform: translateX(12px);
		}

		.work-row-arrow {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	.work-row-link:hover .work-row-preview,
	.work-row-link:focus-visible .work-row-preview {
		opacity: 1;
		transform: translate3d(var(--preview-shift), -57%, 0) scale(1);
	}

	.work-row-link:focus-visible {
		outline: 2px solid var(--orange);
		outline-offset: -2px;
	}

	@media (prefers-color-scheme: dark) {
		.work-page {
			--work-text: var(--light-gray);
			--work-muted: #bec2cc;
			--work-border: rgba(238, 238, 238, 0.2);
			--work-border-hover: rgba(238, 238, 238, 0.34);
		}

		.work-row-preview {
			border-color: rgba(238, 238, 238, 0.28);
		}
	}

	@media screen and (max-width: 1023px) {
		.work-page {
			padding-top: 74px;
		}

		.work-row-link {
			grid-template-columns: minmax(0, 1fr) 24px;
			min-height: 110px;
			padding: 22px 16px;
		}

		.work-row-meta {
			display: none;
		}

		.work-row-description {
			font-size: 0.85rem;
			max-width: 100%;
		}

		.work-row-preview {
			display: none;
		}
	}

	@media screen and (min-width: 1024px) {
		.work-page {
			min-height: 100vh;
		}

		.work-title,
		.work-row-link {
			padding: 24px 0 24px 24px;
		}

		.work-page-cta {
			padding-inline: 24px;
		}

		.work-row:hover {
			border-top-color: var(--work-border-hover);
		}

		.work-row:last-child:hover {
			border-bottom-color: var(--work-border-hover);
		}
	}
</style>
