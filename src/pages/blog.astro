---
import Layout from '../layouts/Layout.astro';

const posts = [
	{
		title: "Design tokens that actually scale",
		category: "Design System",
		date: "January 2026",
		readTime: "7 min read",
		excerpt:
			"How to keep visual consistency between product teams while leaving room for experimentation.",
	},
	{
		title: "Shipping fast without breaking accessibility",
		category: "Front-end",
		date: "December 2025",
		readTime: "6 min read",
		excerpt:
			"A compact workflow to validate semantics, keyboard navigation, and contrast before each release.",
	},
	{
		title: "The right way to structure UI animation",
		category: "Motion",
		date: "November 2025",
		readTime: "5 min read",
		excerpt:
			"Use animation as communication: reveal hierarchy, confirm actions, and reduce visual noise.",
	},
	{
		title: "When Astro is a better fit than heavier stacks",
		category: "Architecture",
		date: "October 2025",
		readTime: "8 min read",
		excerpt:
			"Tradeoffs and decisions from real projects where content, performance, and maintainability mattered most.",
	},
];

const [featuredPost, ...latestPosts] = posts;
---

<Layout title="Blog | SarioDesign" metaDescription="Rosario Russo front-end blog: notes on UI, systems and web architecture">
	<main class="blog-page">
		<section class="blog-hero">
			<p class="blog-eyebrow js-blog-reveal">Journal</p>
			<h1>
				<span class="blog-title-wrap">
					<span class="blog-title-line js-blog-title">Building thoughtful digital products.</span>
				</span>
			</h1>
			<p class="blog-summary js-blog-reveal" cursor-class="text">
				Short notes about front-end engineering, design systems and decisions
				that improve product quality over time.
			</p>
		</section>

		<section class="blog-featured js-blog-reveal" aria-label="Featured article">
			<p class="blog-featured-label">Featured</p>
			<article class="blog-featured-entry" cursor-class="text">
				<div class="blog-entry-meta">
					<span>{featuredPost.category}</span>
					<span>{featuredPost.date}</span>
					<span>{featuredPost.readTime}</span>
				</div>
				<h2 class="blog-entry-title">{featuredPost.title}</h2>
				<p class="blog-entry-excerpt">{featuredPost.excerpt}</p>
			</article>
		</section>

		<section class="blog-list-section">
			<p class="blog-section-title js-blog-reveal">Latest posts</p>
			<ul class="blog-list" aria-label="Latest posts">
				{
					latestPosts.map((post) => (
						<li class="blog-item js-blog-item">
							<article class="blog-entry" cursor-class="text">
								<div class="blog-entry-meta">
									<span>{post.category}</span>
									<span>{post.date}</span>
									<span>{post.readTime}</span>
								</div>
								<h2 class="blog-entry-title">{post.title}</h2>
								<p class="blog-entry-excerpt">{post.excerpt}</p>
							</article>
						</li>
					))
				}
			</ul>
		</section>
	</main>
</Layout>

<script>
	import { gsap } from "gsap";

	const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const titleLine = document.querySelector(".js-blog-title");
	const revealItems = [...document.querySelectorAll(".js-blog-reveal")];
	const cards = [...document.querySelectorAll(".js-blog-item")];

	if (!reduceMotion && titleLine) {
		gsap
			.timeline({ delay: 0.1 })
			.fromTo(
				titleLine,
				{
					yPercent: 120,
					rotateX: -18,
					filter: "blur(8px)",
					opacity: 0,
				},
				{
					yPercent: 0,
					rotateX: 0,
					filter: "blur(0px)",
					opacity: 1,
					duration: 1,
					ease: "power4.out",
				},
			)
			.fromTo(
				revealItems,
				{ y: 20, opacity: 0 },
				{ y: 0, opacity: 1, duration: 0.52, stagger: 0.08, ease: "power3.out" },
				"-=0.55",
			)
			.fromTo(
				cards,
				{ y: 24, opacity: 0 },
				{ y: 0, opacity: 1, duration: 0.45, stagger: 0.08, ease: "power2.out" },
				"-=0.35",
			);
	}
</script>

<style lang="scss" is:global>
	.blog-page {
		--blog-text: var(--dark-black);
		--blog-muted: #6f6a66;
		--blog-border: rgba(16, 32, 32, 0.16);
		display: block;
		min-height: 100vh;
		padding: clamp(88px, 10vh, 126px) 16px 132px;
		position: relative;
		z-index: 2;
	}

	.blog-hero {
		margin: 0 auto 36px;
		max-width: 980px;
	}

	.blog-eyebrow {
		color: var(--blog-muted);
		font-size: 0.78rem;
		letter-spacing: 0.15em;
		margin: 0 0 0.5rem;
		text-transform: uppercase;
	}

	.blog-title-wrap {
		display: block;
		overflow: hidden;
	}

	.blog-title-line {
		color: var(--blog-text);
		display: inline-block;
		font-family: var(--base-font-family-serif);
		font-size: clamp(2rem, 7vw, 5.1rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 0.95;
		transform-origin: 50% 100%;
		will-change: transform, filter, opacity;
	}

	.blog-summary {
		color: var(--blog-muted);
		font-size: clamp(1rem, 1.8vw, 1.24rem);
		line-height: 1.55;
		margin: 1rem 0 0;
		max-width: 62ch;
	}

	.blog-featured,
	.blog-list-section {
		margin: 0 auto;
		max-width: 980px;
	}

	.blog-featured-label,
	.blog-section-title {
		color: var(--blog-muted);
		font-size: 0.74rem;
		letter-spacing: 0.14em;
		margin: 0 0 0.7rem;
		text-transform: uppercase;
	}

	.blog-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--blog-border);
	}

	.blog-featured-entry {
		border-top: 1px solid var(--blog-border);
		border-bottom: 1px solid var(--blog-border);
		margin-bottom: 36px;
		padding: 18px 0 22px;
	}

	.blog-item {
		border-bottom: 1px solid var(--blog-border);
		padding: 18px 0 20px;
	}

	.blog-entry {
		display: grid;
		gap: 0.55rem;
	}

	.blog-entry-meta {
		color: var(--blog-muted);
		display: flex;
		flex-wrap: wrap;
		font-size: 0.73rem;
		gap: 6px 14px;
		letter-spacing: 0.1em;
		margin-bottom: 0.7rem;
		text-transform: uppercase;
	}

	.blog-entry-title {
		color: var(--blog-text);
		font-family: var(--base-font-family-serif);
		font-size: clamp(1.15rem, 2.4vw, 1.75rem);
		line-height: 1.02;
		margin: 0;
	}

	.blog-entry-excerpt {
		color: var(--blog-muted);
		line-height: 1.6;
		margin: 0;
		max-width: 62ch;
	}

	@media screen and (min-width: 1024px) {
		.blog-page {
			padding-inline: 24px;
		}
	}

	@media (prefers-color-scheme: dark) {
		.blog-page {
			--blog-text: #ebebeb;
			--blog-muted: #c0c3cb;
			--blog-border: rgba(238, 238, 238, 0.14);
		}
	}
</style>
