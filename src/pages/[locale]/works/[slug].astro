---
import { getDictionary } from "../../../i18n";
import {
	defaultLocale,
	getLocalizedPath,
	isLocale,
	locales,
	type Locale,
} from "../../../i18n/config";
import Layout from "../../../layouts/Layout.astro";
import WorkDetailPage from "../../../views/WorkDetailPage.astro";

export function getStaticPaths() {
	return locales.flatMap((locale) => {
		const dict = getDictionary(locale);
		return dict.works.projects.map((project) => ({
			params: { locale, slug: project.slug },
		}));
	});
}

const paramLocale = Astro.params.locale ?? defaultLocale;
if (!isLocale(paramLocale)) {
	return Astro.redirect(`/${defaultLocale}`);
}

const locale: Locale = paramLocale;
const dict = getDictionary(locale);
const slug = Astro.params.slug ?? "";
const project = dict.works.projects.find((item) => item.slug === slug);

if (!project) {
	return Astro.redirect(getLocalizedPath(locale, "/works"));
}
---

<Layout
	title={`${project.name} | ${dict.meta.works.title}`}
	metaDescription={project.metaDescription}
	locale={locale}
	pagePath={`/works/${project.slug}`}
>
	<WorkDetailPage dict={dict} locale={locale} project={project} />
</Layout>
