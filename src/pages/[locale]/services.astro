---
import { getDictionary } from "../../i18n";
import {
	defaultLocale,
	isLocale,
	locales,
	type Locale,
} from "../../i18n/config";
import Layout from "../../layouts/Layout.astro";
import ServicesPage from "../../views/ServicesPage.astro";

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const paramLocale = Astro.params.locale ?? defaultLocale;
if (!isLocale(paramLocale)) {
	return Astro.redirect(`/${defaultLocale}`);
}

const locale: Locale = paramLocale;
const dict = getDictionary(locale);
---

<Layout
	title={dict.meta.services.title}
	metaDescription={dict.meta.services.description}
	locale={locale}
	pagePath="/services"
>
	<ServicesPage dict={dict} />
</Layout>
