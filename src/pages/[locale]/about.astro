---
import { getDictionary } from "../../i18n";
import {
	defaultLocale,
	isLocale,
	locales,
	type Locale,
} from "../../i18n/config";
import Layout from "../../layouts/Layout.astro";
import AboutPage from "../../views/AboutPage.astro";

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const paramLocale = Astro.params.locale ?? defaultLocale;
if (!isLocale(paramLocale)) {
	return Astro.redirect(`/${defaultLocale}`);
}

const locale: Locale = paramLocale;
const dict = getDictionary(locale);
---

<Layout
	title={dict.meta.about.title}
	metaDescription={dict.meta.about.description}
	locale={locale}
	pagePath="/about"
>
	<AboutPage dict={dict} locale={locale} />
</Layout>
