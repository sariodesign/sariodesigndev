---
import { slide } from "astro:transitions";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Rosario Russo | Web developer - Front-end & UI/UX - Personal website"
	metaDescription="Rosario Russo | Web developer - Front-end & UI/UX personal website"
>
	<main transition:name="main" transition:animate={slide()}>
			<div>
				<h1 cursor-class="text" id="intro">
				<span class="intro-line-wrap">
					<span class="intro-line">
						I design and build <span class="evidence">fast</span> accessible
						interfaces
					</span>
				</span>
				<span class="intro-line-wrap">
					<span class="intro-line">for modern web products.</span>
				</span>
				</h1>
					<p id="intro-summary" class="intro-summary" cursor-class="text">
						<span class="intro-line-wrap">
							<span class="intro-line">
								I help teams deliver modern digital experiences through
							</span>
						</span>
						<span class="intro-line-wrap">
							<span class="intro-line">
								<span class="summary-highlight">front-end engineering</span> and
								<span class="summary-highlight">Node.js APIs + database architecture</span>,
							</span>
						</span>
						<span class="intro-line-wrap">
							<span class="intro-line">
								with <span class="summary-highlight">design systems based on design tokens</span>.
							</span>
						</span>
					</p>
				</div>
		</main>
	</Layout>

<script>
	import { gsap } from "gsap";

	const intro = document.querySelector("#intro");
	const introLines = document.querySelectorAll(".intro-line");

	if (intro) {
		gsap.set(intro, { autoAlpha: 1 });
	}

	const introTimeline = gsap.timeline({ delay: 0.15 });
	introTimeline.fromTo(
		introLines,
		{
			yPercent: 120,
			rotateX: -22,
			filter: "blur(8px)",
			opacity: 0,
		},
		{
			yPercent: 0,
			rotateX: 0,
			filter: "blur(0px)",
			opacity: 1,
			stagger: 0.13,
			duration: 1.05,
			ease: "power4.out",
		},
	);

	gsap.to(".footer", {
		y: 0,
		opacity: 1,
		stagger: 0.05,
		delay: 0.2,
		duration: 0.5,
	});
</script>

<style is:global>
	h1 {
		color: #fff;
		font-size: clamp(1.25rem, 4vw, 2.75rem);
		line-height: clamp(2.75rem, 4vw, 4.5rem);
		margin: 0;
		opacity: 0;
		perspective: 1000px;
		/* text-align: center; */
		transition: opacity 0.15s;
		visibility: visible;
	}

	.intro-line-wrap {
		display: block;
		overflow: hidden;
	}

	.intro-line {
		display: block;
		transform-origin: 50% 100%;
		will-change: transform, opacity, filter;
	}

		.intro-summary {
			font-size: clamp(1.05rem, 1.7vw, 1.45rem);
			line-height: 1.45;
			margin: 1.35rem 0 0;
			max-width: 52ch;
			opacity: 1;
		}

		.intro-summary .intro-line-wrap + .intro-line-wrap {
			margin-top: 0.12em;
		}

	.summary-highlight {
		color: var(--orange);
		font-weight: 700;
	}

	@media (prefers-color-scheme: dark) {
		h1 {
			color: #fff;
		}

		.intro-summary {
			color: #d4d5df;
		}
	}
	@media (prefers-color-scheme: light) {
		h1 {
			color: var(--dark-black);
		}

		.intro-summary {
			color: #505468;
		}
	}
	.evidence {
		color: var(--orange);
		z-index: -1;
	}

	main {
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		row-gap: 24px;
		min-height: 100vh;
		padding: 0 16px;
	}

	@media screen and (min-width: 1024px) {
		main {
			padding-inline: 24px;
		}
	}

	.footer,
	.btn-menu {
		opacity: 0;
		transform: translateY(50px);
		transition: all 0.15s;
	}

	.rounded {
		width: 30px;
		height: 30px;
		border: 2px solid #fff;
		border-radius: 50%;
		z-index: 999;
	}

	canvas {
		display: block;
		background-color: transparent;
		left: 0;
		position: absolute;
		top: 0;
		z-index: 1;
	}
</style>

<script src="../assets/js/main.js"></script>
