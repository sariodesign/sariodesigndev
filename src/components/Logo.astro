---
import { getLocalizedPath, type Locale } from "../i18n/config";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
---

<div class="logo">
	<a
		class="logo__link"
		cursor-class="link"
		href={getLocalizedPath(locale, "/")}
		data-astro-reload
	>
		{"<sario/design>"}
	</a>
</div>

<style lang="scss">
	.logo {
		font-size: 18px;
		font-weight: 400;
		letter-spacing: 2px;
		position: relative;
		z-index: 1;

		&__link {
			align-items: center;
			display: inline-flex;
			min-height: 44px;
			padding: 4px 0;
			text-decoration: none;

			&:focus-visible {
				outline: 3px solid rgba(221, 122, 76, 0.7);
				outline-offset: 4px;
			}

			@media (prefers-color-scheme: dark) {
				color: var(--white);
			}
			@media (prefers-color-scheme: light) {
				color: var(--dark-black);
			}
		}
	}
</style>
