---
import type { Dictionary } from "../i18n";
import { defaultLocale, getLocalizedPath, type Locale } from "../i18n/config";

interface Props {
	dict: Dictionary;
	locale: Locale;
	className?: string;
}

const { dict, locale, className } = Astro.props;
const worksHref =
	locale === defaultLocale ? "/works" : getLocalizedPath(locale, "/works");
---

<section class:list={["services-cta", className]}>
	<div class="services-cta__copy">
		<h2>{dict.services.ctaTitle}</h2>
		<p>{dict.services.ctaDescription}</p>
	</div>
	<div class="services-cta__actions">
		<a
			class="services-cta__btn services-cta__btn--primary"
			href="mailto:hello@sariodesign.dev"
			cursor-class="link"
		>
			{dict.services.ctaPrimary}
		</a>
		<a
			class="services-cta__btn services-cta__btn--secondary"
			href={worksHref}
			data-astro-reload
			cursor-class="link"
		>
			{dict.services.ctaSecondary}
		</a>
	</div>
</section>

<style lang="scss">
	.services-cta {
		background: linear-gradient(150deg, #102020 0%, #223636 100%);
		border-radius: 24px;
		color: #f6f6f7;
		display: grid;
		gap: 18px;
		padding: clamp(18px, 3.4vw, 34px);
	}

	.services-cta__copy h2 {
		font-family: var(--base-font-family-serif);
		font-size: clamp(1.2rem, 3.1vw, 2rem);
		line-height: 1.1;
		margin: 0 0 8px;
	}

	.services-cta__copy p {
		color: rgba(246, 246, 247, 0.83);
		line-height: 1.6;
		margin: 0;
		max-width: 720px;
	}

	.services-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.services-cta__btn {
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		padding: 0.62rem 0.98rem;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	.services-cta__btn:hover {
		transform: translateY(-1px);
	}

	.services-cta__btn--primary {
		background-color: var(--orange);
		border: 1px solid transparent;
		color: #0f1f1f;
	}

	.services-cta__btn--secondary {
		background-color: transparent;
		border: 1px solid rgba(255, 255, 255, 0.35);
		color: #f6f6f7;
	}
</style>
