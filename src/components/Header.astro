---
import Logo from "../components/Logo.astro";
import MenuIcon from "./MenuIcon.astro";
import Navigation from "../components/Navigation.astro";
import { type Locale } from "../i18n/config";

interface Props {
	locale: Locale;
	currentPagePath: string;
}

const { locale, currentPagePath } = Astro.props;
---

<header class="header">
	<Logo locale={locale} />
	<MenuIcon />
	<Navigation locale={locale} currentPagePath={currentPagePath} />
	<div class="backdrop"></div>
</header>

<style>
	.header {
		align-items: center;
		background-color: transparent;
		display: flex;
		justify-content: space-between;
		left: 0;
		padding: 8px 16px;
		position: fixed;
		top: 0;
		width: 100%;
		z-index: 3;
	}

	@media screen and (min-width: 1024px) {
		.header {
			margin-bottom: 0;
			padding: 16px;
		}
	}
</style>
