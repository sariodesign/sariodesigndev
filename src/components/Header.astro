---
import Logo from "../components/Logo.astro";
import MenuIcon from "./MenuIcon.astro";
import Navigation from "../components/Navigation.astro";
import { type Locale } from "../i18n/config";

interface Props {
	locale: Locale;
	currentPagePath: string;
}

const { locale, currentPagePath } = Astro.props;
---

<header class="header">
	<Logo locale={locale} />
	<MenuIcon locale={locale} />
	<Navigation locale={locale} currentPagePath={currentPagePath} />
</header>

<style lang="scss">
	.header {
		align-items: center;
		background-color: transparent;
		display: flex;
		justify-content: space-between;
		left: 0;
		padding: calc(10px + env(safe-area-inset-top)) 16px 8px;
		position: fixed;
		top: 0;
		transition: opacity 0.2s ease, visibility 0.2s ease;
		width: 100%;
		z-index: 3;
	}

	:global(html.is-lightbox-open) .header,
	:global(body.is-lightbox-open) .header {
		opacity: 0;
		pointer-events: none;
		visibility: hidden;
	}

	@media screen and (min-width: 1024px) {
		.header {
			margin-bottom: 0;
			padding: 16px;
		}
	}
</style>
