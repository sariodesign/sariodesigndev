---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
	defaultLocale,
	getLocalizedPath,
	locales,
	normalizePagePath,
	type Locale,
} from "../i18n/config";

export interface Props {
	title: string;
	metaDescription: string;
	locale: Locale;
	pagePath: string;
}

const { title, metaDescription, locale, pagePath } = Astro.props;
const normalizedPagePath = normalizePagePath(pagePath);
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isLocalizedHomePath = pathname === getLocalizedPath(locale, "/");
const isRootDefaultHome =
	locale === defaultLocale &&
	normalizedPagePath === "/" &&
	pathname === "/";
const isHome = isLocalizedHomePath || isRootDefaultHome;

const canonicalPath = getLocalizedPath(locale, normalizedPagePath);
const xDefaultPath = getLocalizedPath(defaultLocale, normalizedPagePath);

const alternateLinks = locales.map((altLocale) => ({
	locale: altLocale,
	href: getLocalizedPath(altLocale, normalizedPagePath),
}));

const toAbsoluteUrl = (path: string) => {
	if (Astro.site) {
		return new URL(path, Astro.site).toString();
	}
	return path;
};
---

<!doctype html>
<html lang={locale} class:list={["theme-light", "js-page", isHome && "is-home"]}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&family=Roboto+Serif:opsz,wght@8..144,700&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={metaDescription} />
		<link rel="canonical" href={toAbsoluteUrl(canonicalPath)} />
		{
			alternateLinks.map((alternate) => (
				<link
					rel="alternate"
					hreflang={alternate.locale}
					href={toAbsoluteUrl(alternate.href)}
				/>
			))
		}
		<link rel="alternate" hreflang="x-default" href={toAbsoluteUrl(xDefaultPath)} />
		<script>
			window.va =
				window.va ||
				function () {
					(window.vaq = window.vaq || []).push(arguments);
				};
		</script>
		<script defer src="/_vercel/insights/script.js"></script>
		<title>{title}</title>
		<style>
			h1 {
				opacity: 0;
			}
		</style>
	</head>
	<body class:list={["js-body", isHome && "is-home"]}>
		<div id="page-loader" aria-hidden="true">
			<div class="page-loader__inner">
				<span class="page-loader__brand js-page-loader-brand">&lt;sario/design&gt;</span>
			</div>
		</div>
		{
			isHome && (
				<div id="cursor">
					<div class="cursor__circle" />
				</div>
				)
		}
		<Header locale={locale} currentPagePath={normalizedPagePath} />
		<slot />
		<Footer locale={locale} />
	</body>
</html>
<style is:global lang="scss">
	:root {
		--dark-black: #102020;
		--light-gray: #eee;
		--white: #fff;
		--orange: #dd7a4c;
		--base-font-family: "Roboto Mono", monospace;
		--base-font-family-serif: "Roboto Serif", monospace;
		--header-bg: rgba(255, 255, 255, 0.85);
	}

	* {
		box-sizing: border-box;
	}

	html {
		overflow-x: hidden;

		&.is-locked {
			overflow-y: hidden;
		}

		&.is-loading-page {
			overflow: hidden;
		}
	}
	body {
		display: flex;
		flex-direction: column;
		font-family: var(--base-font-family);
		font-size: 16px;
		margin: 0;
		min-height: 100vh;
		min-height: 100dvh;
		overflow-x: hidden;

		.is-locked & {
			overflow-y: hidden;
		}
	}

	body > main {
		flex: 1 0 auto;
		width: 100%;
	}

	body.is-home a:hover {
		cursor: pointer;
	}

	html.is-home,
	body.is-home {
		cursor: none;
	}

	#page-loader {
		position: fixed;
		inset: 0;
		align-items: center;
		background:
			radial-gradient(
				circle at 25% 20%,
				rgba(221, 122, 76, 0.16),
				transparent 48%
			),
			radial-gradient(
				circle at 75% 80%,
				rgba(255, 255, 255, 0.06),
				transparent 52%
			),
			linear-gradient(160deg, #0f1f1f 0%, #102020 65%, #182626 100%);
		display: flex;
		justify-content: center;
		opacity: 1;
		transition:
			opacity 0.28s ease,
			visibility 0.28s ease;
		visibility: visible;
		z-index: 200;
	}

	#page-loader.is-hidden {
		opacity: 0;
		pointer-events: none;
		visibility: hidden;
	}

	.page-loader__inner {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 24px;
		text-align: center;
	}

	.page-loader__brand {
		color: var(--white);
		display: inline-flex;
		font-family: var(--base-font-family);
		font-size: clamp(16px, 2.4vw, 18px);
		font-weight: 400;
		gap: 0;
		letter-spacing: 2px;
		line-height: 1;
		text-shadow:
			0 0 14px rgba(97, 220, 163, 0.12),
			0 0 22px rgba(221, 122, 76, 0.08);
		white-space: nowrap;
	}

	.page-loader__brand.is-complete {
		text-shadow:
			0 0 16px rgba(255, 255, 255, 0.12);
	}

	.page-loader__char {
		display: inline-block;
		filter: blur(8px);
		min-width: 0.62ch;
		opacity: 0;
		text-align: center;
		transform: translateY(8px) scale(0.97);
		transition:
			color 0.24s ease,
			opacity 0.24s ease,
			transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
			filter 0.24s ease;
		will-change: color, opacity, transform, filter;
	}

	.page-loader__char.is-active {
		filter: blur(0);
		opacity: 0.92;
		transform: translateY(0) scale(1);
	}

	.page-loader__char.is-accent-a {
		color: #61dca3;
	}

	.page-loader__char.is-accent-b {
		color: var(--orange);
	}

	.page-loader__char.is-settled {
		color: var(--white);
		opacity: 1;
	}

	main {
		align-items: center;
		display: flex;
		justify-content: center;
	}

	h1 {
		font-family: var(--base-font-family);

		span {
			font-family: var(--base-font-family-serif);
		}
	}
	@media (prefers-color-scheme: dark) {
		html {
			background-color: var(--dark-black);
		}
	}

	@media (prefers-color-scheme: light) {
		html {
			background-color: var(--light-gray);
		}
	}

	.btn-menu {
		border: 0;
		bottom: 16px;
		border-radius: 50%;
		box-shadow: 0 5px 15px -5px rgba(0, 0, 0, 0.5);
		height: 48px;
		position: fixed;
		right: 16px;
		width: 48px;
		z-index: 2;
		@media screen and (min-width: 1024px) {
			display: none;
		}

		@media (prefers-color-scheme: light) {
			background-color: var(--dark-black);

			svg {
				height: 24px;
				fill: var(--orange);
				width: 24px;
			}
		}
	}

	#cursor {
		position: fixed;
		z-index: 99;
		left: 0;
		top: 0;
		pointer-events: none;
		will-change: transform;
		mix-blend-mode: difference;
	}

	@media (hover: hover) and (pointer: fine) {
		.cursor__circle {
			background-color: var(--white);
			width: 32px;
			height: 32px;
			margin-top: -50%;
			margin-left: -50%;
			border-radius: 50%;
			transition:
				opacity 0.16s cubic-bezier(0.25, 1, 0.5, 1),
				background-color 0.16s cubic-bezier(0.25, 1, 0.5, 1),
				border-color 0.16s cubic-bezier(0.25, 1, 0.5, 1),
				width 0.14s cubic-bezier(0.25, 1, 0.5, 1),
				height 0.14s cubic-bezier(0.25, 1, 0.5, 1);
		}

		.text .cursor__circle {
			width: 64px;
			height: 64px;
		}

		.link .cursor__circle {
			opacity: 0;
			width: 0;
			height: 0;
			transition: opacity 0.08s ease;
		}

		.photo-home .cursor__circle {
			width: 64px;
			height: 64px;
		}

		@media screen and (min-width: 1024px) {
			.photo .cursor__circle {
				height: 140px;
				width: 140px;
			}
		}

		@media screen and (min-width: 1366px) {
			.photo .cursor__circle {
				height: 160px;
				width: 160px;
			}

			.square .cursor__circle {
				background-color: transparent;
				border-radius: 2px;
				border: 2px solid var(--orange);
				height: 40px;
				width: 100px;
			}
		}
	}

	.contact-links {
		display: none;
		gap: 16px;

		@media screen and (min-width: 1024px) {
			display: flex;
		}
	}

	.contact-link {
		display: inline-flex;
		font-size: 14px;
		gap: 8px;
		align-items: center;
		transition: all 0.25s linear;
		text-decoration: none;

		@media (prefers-color-scheme: dark) {
			color: var(--white);
		}
		@media (prefers-color-scheme: light) {
			color: var(--dark-black);
		}
	}

	.link {
		font-size: 40px;
		font-family: var(--base-font-family-serif);
		font-weight: 700;
		position: relative;
		text-transform: capitalize;
		text-decoration: none;
		transition: all 0.25s ease-in-out;

		&:after {
			content: "";
			left: 0;
			position: absolute;
			height: 2px;
			transition: all 0.25s linear;
			top: calc(100% - 2px);
			width: 0;
		}

		&:hover {
			//transform: scale(1.1);
			text-decoration: none;
		}

		&:hover::after {
			@media screen and (hover: hover) {
				background-color: var(--dark-black);
				width: 100%;
			}
		}

		@media screen and (min-width: 1024px) {
			font-size: 18px;
		}

		@media (prefers-color-scheme: dark) {
			color: var(--light-gray);
		}

		@media (prefers-color-scheme: light) {
			color: var(--dark-black);
		}
	}
</style>

<script>
	import { initPageLoader } from "../assets/js/loader.js";

	initPageLoader();

	const cursor = document.querySelector<HTMLElement>("#cursor");
	const cursorCircle = cursor?.querySelector<HTMLElement>(".cursor__circle");

	if (cursor && cursorCircle) {
		const mouse = { x: -100, y: -100 }; // mouse pointer's coordinates
		const pos = { x: 0, y: 0 }; // cursor's coordinates
		const speed = 0.24; // between 0 and 1

		const updateCoordinates = (e) => {
			mouse.x = e.clientX;
			mouse.y = e.clientY;
		};

		window.addEventListener("mousemove", updateCoordinates);

		function getAngle(diffX, diffY) {
			return (Math.atan2(diffY, diffX) * 180) / Math.PI;
		}

		function getSqueeze(diffX, diffY) {
			const distance = Math.sqrt(Math.pow(diffX, 2) + Math.pow(diffY, 2));
			const maxSqueeze = 0.15;
			const accelerator = 1500;
			return Math.min(distance / accelerator, maxSqueeze);
		}

			const updateCursor = () => {
				if (cursor.classList.contains("link")) {
					pos.x = mouse.x;
					pos.y = mouse.y;
					cursor.style.transform =
						"translate3d(" + pos.x + "px ," + pos.y + "px, 0)";
					cursorCircle.style.transform = "none";
					return;
				}

				const diffX = Math.round(mouse.x - pos.x);
				const diffY = Math.round(mouse.y - pos.y);

			pos.x += diffX * speed;
			pos.y += diffY * speed;

			const angle = getAngle(diffX, diffY);
			const squeeze = getSqueeze(diffX, diffY);

			const scale = "scale(" + (1 + squeeze) + ", " + (1 - squeeze) + ")";
			const rotate = "rotate(" + angle + "deg)";
			const translate =
				"translate3d(" + pos.x + "px ," + pos.y + "px, 0)";

			cursor.style.transform = translate;
			cursorCircle.style.transform = rotate + scale;
		};

		function loop() {
			updateCursor();
			requestAnimationFrame(loop);
		}

		requestAnimationFrame(loop);

		const cursorModifiers = document.querySelectorAll("[cursor-class]");

		cursorModifiers.forEach((curosrModifier) => {
			curosrModifier.addEventListener("mouseenter", function () {
				const className = this.getAttribute("cursor-class");
				cursor.classList.add(className);
			});

			curosrModifier.addEventListener("mouseleave", function () {
				const className = this.getAttribute("cursor-class");
				cursor.classList.remove(className);
			});
		});
	}
</script>
